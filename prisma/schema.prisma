// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  document  String?
  plan      String   @default("free") // Legacy field, keeping for compatibility
  status    String   @default("active")

  // SaaS Billing Fields
  platformPlanId        String?
  platformPlan          PlatformPlan? @relation(fields: [platformPlanId], references: [id])
  billingStatus         String    @default("trialing") // trialing, active, past_due, canceled, suspended
  trialEndsAt           DateTime?
  currentPeriodEnd      DateTime?
  billingProvider       String?   // manual, stripe, mercado_pago, asaas
  billingCustomerId     String?
  billingSubscriptionId String?
  billingInvoices       BillingInvoice[]
  usageMeters           UsageMeter[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                  TenantUser[]
  products               Product[]
  customers              Customer[]
  orders                 Order[]
  stockMovements         StockMovement[]
  financialTransactions  FinancialTransaction[]
  auditLogs              AuditLog[]
  roles                  Role[]
  invitations            Invitation[]
  settings               AppSetting[]
  locations              StockLocation[]
  lots                   Lot[]
  costCenters            CostCenter[]
  productionBatches      ProductionBatch[]
  consignments           Consignment[]
  consignmentSettlements ConsignmentSettlement[]
  branches               Branch[]
  documents              GeneratedDocument[]
  subscriptionPlans      SubscriptionPlan[]
  subscriptionRequests   SubscriptionRequest[]
  subscriptions          Subscription[]
  paymentProviderConfigs PaymentProviderConfig[]
  paymentIntents         PaymentIntent[]
  paymentTransactions    PaymentTransaction[]
  paymentWebhookEvents   PaymentWebhookEvent[]
  paymentReconciliations PaymentReconciliation[]
  // Crm
  crmPipelines           CrmPipeline[]
  crmStages              CrmStage[]
  crmDeals               CrmDeal[]
  crmActivities          CrmActivity[]
  crmConversations       CrmConversation[]
  crmChannelConnections  CrmChannelConnection[]
  crmAutomationWorkflows CrmAutomationWorkflow[]
  crmCampaigns           CrmCampaign[]
  crmMessages            CrmMessage[]
  crmTrackingLinks       CrmTrackingLink[]
  portalSessions         PortalSession[]
  crmAutomationLogs      CrmAutomationLog[]
  communicationTemplates CommunicationTemplate[]
  communicationQueues    CommunicationQueue[]

  // Production Advanced
  greenCoffeeLots         GreenCoffeeLot[]
  inputReservations       ProductionInputReservation[]
  productionRecipes       ProductionRecipe[]
  productionRecipeInputs  ProductionRecipeInput[]
  productionRecipeExtras  ProductionRecipeExtra[]
  roastProfiles           RoastProfile[]
  b2bCatalogItems         B2BCatalogItem[]
  // Quality
  qualityReviews          QualityReview[]
  sensoryDescriptors      SensoryDescriptor[]
  qualityDefects          QualityDefect[]
  publicLotTraces         PublicLotTrace[]
  digitalMenuConfig       DigitalMenuConfig?
  digitalMenuCategories   DigitalMenuCategory[]
  digitalMenuItems        DigitalMenuItem[]
  digitalMenuModifierGrps DigitalMenuModifierGroup[]
  digitalMenuModifierOpts DigitalMenuModifierOption[]
  PlatformFeeLedger       PlatformFeeLedger[]
  OAuthState              OAuthState[]

  // Phase 8B Vertical CRM
  specialOrders           SpecialOrder[]
  calendarEvents          CalendarEvent[]
  loyaltyProgram          LoyaltyProgram?
  loyaltyEvents           LoyaltyEvent[]
  customerFeedbacks       CustomerFeedback[]
  serviceTickets          ServiceTicket[]
}

model GeneratedDocument {
  id                String    @id @default(uuid())
  tenantId          String
  type              String // receipt, shipment, settlement, production, statement, report
  status            String    @default("active") // active, voided
  sequenceNumber    Int       @default(autoincrement())
  referenceType     String?
  referenceId       String?
  customerId        String?
  periodStart       DateTime?
  periodEnd         DateTime?
  title             String
  snapshotJson      String    @db.Text
  generatedByUserId String
  generatedAt       DateTime  @default(now())
  voidedAt          DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

model Branch {
  id           String    @id @default(uuid())
  tenantId     String
  name         String
  type         String    @default("loja") // matriz, loja, estoque, torrefacao, escritorio
  street       String?
  number       String?
  complement   String?
  neighborhood String?
  city         String?
  state        String?
  postalCode   String?
  country      String    @default("BR")
  isDefault    Boolean   @default(false)
  status       String    @default("active") // active, inactive
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  tenantUsers TenantUser[]
  invitations Invitation[]
}

model User {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  phone        String?
  passwordHash String
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenants         TenantUser[]
  auditLogs       AuditLog[]
  invitationsSent Invitation[] @relation("InvitedBy")
}

model Role {
  id          String    @id @default(uuid())
  tenantId    String? // null if system default role
  name        String
  description String?
  systemKey   String?
  isSystem    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  deletedAt   DateTime?

  tenant      Tenant?          @relation(fields: [tenantId], references: [id])
  tenantUsers TenantUser[]
  permissions RolePermission[]
  invitations Invitation[]
}

model Permission {
  key         String  @id
  module      String
  action      String
  description String?

  roles RolePermission[]
}

model RolePermission {
  roleId        String
  permissionKey String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionKey], references: [key], onDelete: Cascade)

  @@id([roleId, permissionKey])
}

model TenantUser {
  tenantId    String
  userId      String
  roleId      String?
  branchId    String?
  status      String    @default("active") // active, suspended, inactive
  suspendedAt DateTime?
  createdAt   DateTime  @default(now())

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  user   User    @relation(fields: [userId], references: [id])
  role   Role?   @relation(fields: [roleId], references: [id])
  branch Branch? @relation(fields: [branchId], references: [id])

  @@id([tenantId, userId])
}

model Invitation {
  id              String    @id @default(uuid())
  tenantId        String
  email           String
  roleId          String?
  branchId        String?
  status          String    @default("pending") // pending, accepted, expired, canceled
  tokenHash       String
  invitedByUserId String?
  expiresAt       DateTime
  acceptedAt      DateTime?
  createdAt       DateTime  @default(now())

  tenant        Tenant  @relation(fields: [tenantId], references: [id])
  role          Role?   @relation(fields: [roleId], references: [id])
  branch        Branch? @relation(fields: [branchId], references: [id])
  invitedByUser User?   @relation("InvitedBy", fields: [invitedByUserId], references: [id])
}

model SubscriptionPlan {
  id           String    @id @default(uuid())
  tenantId     String
  name         String
  description  String?
  frequency    String    @default("monthly") // weekly, biweekly, monthly
  packageCount Int       @default(1)
  weight       Float?
  price        Float
  active       Boolean   @default(true)
  featured     Boolean   @default(false)
  productId    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  tenant        Tenant                @relation(fields: [tenantId], references: [id])
  product       Product?              @relation(fields: [productId], references: [id])
  requests      SubscriptionRequest[]
  subscriptions Subscription[]
}

model SubscriptionRequest {
  id            String   @id @default(uuid())
  tenantId      String
  planId        String
  customerName  String
  customerEmail String
  customerPhone String?
  address       String?
  notes         String?
  status        String   @default("pending") // pending, contacted, approved, rejected
  customerId    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant         Tenant               @relation(fields: [tenantId], references: [id])
  plan           SubscriptionPlan     @relation(fields: [planId], references: [id])
  customer       Customer?            @relation(fields: [customerId], references: [id])
  paymentIntents PaymentIntent[]
  crmDeals       CrmDeal[]
  communications CommunicationQueue[]
}

model Subscription {
  id            String    @id @default(uuid())
  tenantId      String
  planId        String
  customerId    String
  status        String    @default("active") // active, paused, cancelled
  startedAt     DateTime  @default(now())
  nextBillingAt DateTime?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant         Tenant           @relation(fields: [tenantId], references: [id])
  plan           SubscriptionPlan @relation(fields: [planId], references: [id])
  customer       Customer         @relation(fields: [customerId], references: [id])
  paymentIntents PaymentIntent[]
  crmDeals       CrmDeal[]
}

model Product {
  id          String    @id @default(uuid())
  tenantId    String
  sku         String?
  name        String
  category    String
  description String?
  unit        String    @default("un")
  unitCost    Float     @default(0)
  unitPrice   Float     @default(0)
  active      Boolean   @default(true)
  minStock    Float     @default(0)
  isInput     Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  tenant                     Tenant                      @relation(fields: [tenantId], references: [id])
  variants                   ProductVariant[]
  orderItems                 OrderItem[]
  stockMovements             StockMovement[]
  lots                       Lot[]
  productionRecipes          ProductionRecipe[]
  b2bCatalogItems            B2BCatalogItem[]
  productionBatches          ProductionBatch[] // Final product
  productionInputs           ProductionInput[] // As input
  consignmentItems           ConsignmentItem[]
  consignmentSettlementItems ConsignmentSettlementItem[]
  subscriptionPlans          SubscriptionPlan[]
  qualityReviews             QualityReview[]
  publicLotTraces            PublicLotTrace[]
  DigitalMenuItem            DigitalMenuItem[]
}

model ProductVariant {
  id        String  @id @default(uuid())
  productId String
  name      String
  sku       String?
  price     Float?

  product        Product         @relation(fields: [productId], references: [id])
  stockMovements StockMovement[]
  orderItems     OrderItem[]
}

model StockLocation {
  id       String @id @default(uuid())
  tenantId String
  name     String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  stockMovements StockMovement[]
}

model Lot {
  id             String    @id @default(uuid())
  tenantId       String
  productId      String
  code           String
  initialQty     Float
  currentQty     Float
  manufacturedAt DateTime?
  expiryDate     DateTime?
  createdAt      DateTime  @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  stockMovements StockMovement[]
}

model StockMovement {
  id            String    @id @default(uuid())
  tenantId      String
  productId     String
  variantId     String?
  lotId         String?
  locationId    String?
  movementType  String
  qty           Float
  unitCost      Float     @default(0)
  reason        String?
  notes         String?
  referenceType String?
  referenceId   String?
  userId        String?
  createdAt     DateTime  @default(now())
  deletedAt     DateTime?

  tenant   Tenant          @relation(fields: [tenantId], references: [id])
  product  Product         @relation(fields: [productId], references: [id])
  variant  ProductVariant? @relation(fields: [variantId], references: [id])
  lot      Lot?            @relation(fields: [lotId], references: [id])
  location StockLocation?  @relation(fields: [locationId], references: [id])
}

model Customer {
  id                      String    @id @default(uuid())
  tenantId                String
  type                    String    @default("b2c") // b2c, b2b, partner, supplier
  name                    String
  legalName               String?
  documentType            String    @default("none") // cpf, cnpj, none
  document                String?
  email                   String?
  phone                   String?
  whatsapp                String?
  city                    String?
  state                   String?
  status                  String    @default("active") // active, inactive, blocked
  defaultPaymentTermsDays Int       @default(0)
  creditLimit             Float?
  notes                   String?
  tags                    String?
  whatsappOptIn           Boolean   @default(false)
  smsOptIn                Boolean   @default(false)
  score                   Int       @default(0)
  origin                  String?
  lastContactAt           DateTime?
  nextContactAt           DateTime?
  totalPurchased          Float     @default(0)

  // Phase 8A: Local Food CRM fields
  loyaltyPoints           Int       @default(0)
  loyaltyLevel            String?   // Bronze, Prata, Ouro, Black
  favoriteProducts        String?
  dietaryRestrictions     String?
  purchaseFrequency       Float?    
  lastPurchaseAt          DateTime?
  riskOfChurn             Boolean   @default(false)
  npsScore                Int?

  createdBy               String?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  deletedAt               DateTime?

  tenant               Tenant                @relation(fields: [tenantId], references: [id])
  addresses            CustomerAddress[]
  orders               Order[]
  consignments         Consignment[]
  subscriptionRequests SubscriptionRequest[]
  subscriptions        Subscription[]
  paymentIntents       PaymentIntent[]
  CrmDeal              CrmDeal[]
  CrmActivity          CrmActivity[]
  CommunicationQueue   CommunicationQueue[]
  CrmConversation      CrmConversation[]

  specialOrders        SpecialOrder[]
  loyaltyEvents        LoyaltyEvent[]
  customerFeedbacks    CustomerFeedback[]
  serviceTickets       ServiceTicket[]
}

model CustomerAddress {
  id           String  @id @default(uuid())
  customerId   String
  street       String
  number       String
  complement   String?
  neighborhood String?
  city         String
  state        String
  postalCode   String?
  country      String  @default("BR")
  isDefault    Boolean @default(false)

  customer Customer @relation(fields: [customerId], references: [id])
}

model Order {
  id              String    @id @default(uuid())
  tenantId        String
  customerId      String?
  customerName    String?
  channel         String    @default("pdv")
  trackingNumber  String?
  orderDate       DateTime  @default(now())
  subtotal        Float
  discount        Float     @default(0)
  total           Float
  estimatedCost   Float     @default(0)
  estimatedProfit Float     @default(0)
  estimatedMargin Float     @default(0)
  paymentMethod   String?
  paymentStatus   String    @default("pending")
  status          String    @default("confirmed")
  dueDate         DateTime?
  notes           String?
  createdBy       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  tenant                Tenant                 @relation(fields: [tenantId], references: [id])
  customer              Customer?              @relation(fields: [customerId], references: [id])
  items                 OrderItem[]
  financialTransactions FinancialTransaction[]
  paymentIntents        PaymentIntent[]
  crmDeals              CrmDeal[]
  PlatformFeeLedger     PlatformFeeLedger[]

  @@unique([tenantId, trackingNumber])
}

model OrderItem {
  id              String  @id @default(uuid())
  orderId         String
  productId       String?
  variantId       String?
  name            String
  sku             String?
  qty             Float
  unitPrice       Float
  unitCost        Float   @default(0)
  discount        Float   @default(0)
  lineTotal       Float
  estimatedProfit Float   @default(0)
  notes           String?
  modifiersJson   String? @db.Text

  order   Order           @relation(fields: [orderId], references: [id])
  product Product?        @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])
}

model DigitalMenuModifierGroup {
  id            String   @id @default(uuid())
  tenantId      String
  itemId        String
  name          String
  description   String?
  minSelections Int      @default(0)
  maxSelections Int      @default(1)
  active        Boolean  @default(true)
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant  Tenant                      @relation(fields: [tenantId], references: [id])
  item    DigitalMenuItem             @relation(fields: [itemId], references: [id])
  options DigitalMenuModifierOption[]
}

model DigitalMenuModifierOption {
  id        String   @id @default(uuid())
  tenantId  String
  groupId   String
  name      String
  price     Float    @default(0)
  active    Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant                   @relation(fields: [tenantId], references: [id])
  group  DigitalMenuModifierGroup @relation(fields: [groupId], references: [id])
}

model CostCenter {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  createdAt DateTime @default(now())

  tenant                Tenant                 @relation(fields: [tenantId], references: [id])
  financialTransactions FinancialTransaction[]
}

model FinancialTransaction {
  id              String    @id @default(uuid())
  tenantId        String
  orderId         String?
  type            String
  status          String    @default("pending")
  category        String
  description     String
  amount          Float
  paidAmount      Float     @default(0)
  grossAmount     Float?
  providerFee     Float?
  platformFee     Float?
  netAmount       Float?
  dueDate         DateTime?
  paidAt          DateTime?
  date            DateTime
  paymentMethod   String?
  referenceId     String?
  source          String?
  providerEventId String?
  createdBy       String?
  costCenterId    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  tenant          Tenant                  @relation(fields: [tenantId], references: [id])
  order           Order?                  @relation(fields: [orderId], references: [id])
  costCenter      CostCenter?             @relation(fields: [costCenterId], references: [id])
  reconciliations PaymentReconciliation[]

  // Optional idempotency keys - composite unique index doesn't work well if fields are optional in Postgres,
  // but we can add standard indices for faster lookups when verifying idempotency
  @@index([tenantId, referenceId, source])
  @@index([providerEventId])
}

model ProductionBatch {
  id               String   @id @default(uuid())
  tenantId         String
  code             String
  date             DateTime
  finalProductId   String
  finalProductName String
  status           String   @default("draft") // "draft", "completed", "cancelled"

  initialWeight Float
  finalWeight   Float
  finalQty      Float

  yieldPercent Float
  lossPercent  Float

  hours            Float @default(0)
  laborCostPerHour Float @default(0)

  totalInputCost Float @default(0)
  totalLaborCost Float @default(0)
  totalExtraCost Float @default(0)
  totalCost      Float @default(0)

  unitCost Float @default(0)

  responsible String?
  notes       String?

  createdBy String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Advanced Production Fields
  recipeId        String?
  roastProfileId  String?
  plannedDate     DateTime?
  masterRoasterId String?
  costPerKg       Float     @default(0)
  packagedQty     Int       @default(0)
  finalLotCreated String?

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  product Product @relation(fields: [finalProductId], references: [id])

  recipe       ProductionRecipe?            @relation(fields: [recipeId], references: [id])
  roastProfile RoastProfile?                @relation(fields: [roastProfileId], references: [id])
  reservations ProductionInputReservation[]

  inputs     ProductionInput[]
  extraCosts ProductionExtraCost[]

  qualityReviews QualityReview[]
  publicLotTrace PublicLotTrace?
}

model ProductionInput {
  id        String @id @default(uuid())
  batchId   String
  productId String
  name      String
  qty       Float
  unitCost  Float

  batch   ProductionBatch @relation(fields: [batchId], references: [id])
  product Product         @relation(fields: [productId], references: [id])
}

model ProductionExtraCost {
  id          String @id @default(uuid())
  batchId     String
  description String
  amount      Float

  batch ProductionBatch @relation(fields: [batchId], references: [id])
}

model AuditLog {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String?
  action    String
  tableName String
  recordId  String
  oldData   Json?
  newData   Json?
  ip        String?
  timestamp DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User?  @relation(fields: [userId], references: [id])
}

model AppSetting {
  tenantId String
  key      String
  value    String

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@id([tenantId, key])
}

// Consignments

model Consignment {
  id                 String    @id @default(uuid())
  tenantId           String
  partnerId          String
  partnerName        String
  date               DateTime
  expectedReturnDate DateTime?
  status             String    @default("open") // open, due_soon, overdue, partially_settled, closed, cancelled
  totalValue         Float     @default(0)
  totalCost          Float     @default(0)
  notes              String?
  createdBy          String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  partner Customer @relation(fields: [partnerId], references: [id])

  items       ConsignmentItem[]
  settlements ConsignmentSettlement[]
}

model ConsignmentItem {
  id            String @id @default(uuid())
  consignmentId String
  productId     String
  name          String
  sentQty       Float
  soldQty       Float  @default(0)
  returnedQty   Float  @default(0)
  lostQty       Float  @default(0)
  unitCost      Float  @default(0)
  unitPrice     Float  @default(0)

  consignment Consignment @relation(fields: [consignmentId], references: [id])
  product     Product     @relation(fields: [productId], references: [id])
}

model ConsignmentSettlement {
  id            String   @id @default(uuid())
  tenantId      String
  consignmentId String
  date          DateTime
  totalValue    Float    @default(0)
  discount      Float    @default(0)
  paymentMethod String?
  notes         String?
  orderId       String? // Reference to built Order
  createdBy     String?
  createdAt     DateTime @default(now())

  tenant      Tenant                      @relation(fields: [tenantId], references: [id])
  consignment Consignment                 @relation(fields: [consignmentId], references: [id])
  items       ConsignmentSettlementItem[]
}

model ConsignmentSettlementItem {
  id           String @id @default(uuid())
  settlementId String
  productId    String
  name         String
  soldQty      Float  @default(0)
  returnedQty  Float  @default(0)
  lostQty      Float  @default(0)
  unitPrice    Float  @default(0)
  unitCost     Float  @default(0)

  settlement ConsignmentSettlement @relation(fields: [settlementId], references: [id])
  product    Product               @relation(fields: [productId], references: [id])
}

// TODO: Fiscal Exports

model PlatformFeeLedger {
  id              String   @id @default(uuid())
  tenantId        String
  orderId         String?
  amount          Float
  paymentIntentId String?
  status          String   @default("pending") // pending, settled
  description     String
  createdAt       DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  order  Order? @relation(fields: [orderId], references: [id])
}

model OAuthState {
  id                    String    @id @default(uuid())
  tenantId              String
  userId                String?
  stateHash             String    @unique
  codeVerifierEncrypted String
  expiresAt             DateTime
  consumedAt            DateTime?
  createdAt             DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

model PaymentProviderConfig {
  id           String    @id @default(uuid())
  tenantId     String
  provider     String    @default("manual") // manual, mock, stripe, mercadopago
  mode         String    @default("mock") // mock, manual, live, sandbox
  enabled      Boolean   @default(true)
  publicLabel  String    @default("Pagamento Manual")
  accessToken  String?   @db.Text
  refreshToken String?   @db.Text
  publicKey    String?
  userId       String?
  expiresAt    DateTime?
  metadataJson String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

model PaymentIntent {
  id                    String    @id @default(uuid())
  tenantId              String
  customerId            String?
  orderId               String?
  subscriptionRequestId String?
  subscriptionId        String?
  amount                Float
  platformFeeAmount     Float?
  currency              String    @default("BRL")
  status                String    @default("pending") // pending, processing, paid, failed, cancelled, refunded, expired
  provider              String    @default("manual")
  providerIntentId      String?
