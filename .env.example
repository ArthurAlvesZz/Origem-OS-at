# Environment Setup
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# App Modes
# DATA_MODE: use 'api' to connect to Postgres. Use 'mock' for in-memory frontend mock
DATA_MODE=mock
# PAYMENT_MODE: 'manual', 'mock', or standard payment gateway integrations
PAYMENT_MODE=manual
ENABLE_DEV_QA_PANEL=false

# URLs
# MUST point to your domain in production for Webhooks and Links
PUBLIC_APP_URL=http://localhost:3000

# Security (MUST BE CHANGED IN PRODUCTION)
JWT_SECRET=super_secret_key_change_me_must_be_long
JWT_EXPIRES_IN=24h
CORS_ORIGIN=*

# Database
# Used by Prisma to connect to the PostgreSQL database.
# In development, you can use docker-compose or a local postgres default port
# DATABASE_URL="postgresql://user:password@localhost:5432/gestaoos?schema=public"

# Database Test (used for npm run test:db)
# Should point to a different, safe database instance for integration tests
# DATABASE_URL_TEST="postgresql://user:password@localhost:5432/gestaoos_test?schema=public"

# Payment Encryption Key (minimum 16 bytes/chars)
# Used to verify payload idempotency hashes internally
PAYMENTS_ENCRYPTION_KEY=super_secret_32_bytes_payment_key

# Mercado Pago Integration (Optional)
# If missing, the app defaults to "manual pix" flow.
# MP_CLIENT_ID=
# MP_CLIENT_SECRET=
MP_REDIRECT_URI=http://localhost:3000/api/payments/mercadopago/callback
# MP_WEBHOOK_SECRET=


