{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:db": "vitest run tests/db",
    "test:all": "vitest run tests",
    "verify": "npm run check:env && npm run typecheck && npm run test:integration && npm run test:db && npm run build",
    "check:env": "tsx scripts/check-env.ts",
    "db:up": "docker-compose up -d db",
    "db:down": "docker-compose down",
    "db:logs": "docker-compose logs -f db",
    "db:wait": "echo 'Waiting for postgres...' && sleep 5",
    "db:setup:dev": "npm run db:up && npm run db:wait && npx prisma migrate dev && npx prisma generate && npx prisma db seed",
    "db:setup:test": "DATABASE_URL=$DATABASE_URL_TEST npx prisma migrate deploy",
    "db:test:reset": "DATABASE_URL=$DATABASE_URL_TEST npx prisma migrate reset --force --skip-seed",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "db:reset:dev": "prisma migrate reset",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:seed": "prisma db seed",
    "db:setup": "prisma generate && prisma migrate deploy && prisma db seed"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@prisma/client": "^5.22.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "framer-motion": "^12.40.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.40.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-qr-code": "^2.0.21",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0",
    "vite": "^6.2.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.14.0",
    "@types/supertest": "^7.2.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "prisma": "^5.22.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.8"
  }
}
